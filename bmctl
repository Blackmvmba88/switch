#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEBUG_PORT="${DEBUG_PORT:-9224}"
APP_PORT="${BM_APP_PORT:-8147}"
APP_STATUS="${HOME}/Library/Application Support/BlackMambaInput/reports/live-status.json"
XCLOUD_STATUS="${HOME}/Library/Application Support/BlackMambaInput/reports/xcloud-bridge-status.json"
SESSION_STATUS="${HOME}/Library/Application Support/BlackMambaInput/reports/play-sessions.json"
NETWORK_STATUS="${HOME}/Library/Application Support/BlackMambaInput/reports/network-game-status.json"
APP_HID_PID_FILE="${HOME}/Library/Application Support/BlackMambaInput/logs/hid-live-source.pid"
HID_BIN="${ROOT}/.tmp-runtime-test/hid-live-source"
HID_PID_FILE="${ROOT}/logs/hid-live-source.pid"

usage() {
  cat <<'HELP'
BlackMamba Input Runtime metacomandos

Uso:
  ./bmctl play              Abre xCloud con puente CDP + HID source
  ./bmctl wake              Levanta Chrome CDP/xCloud sin tocar daemons
  ./bmctl reinject          Reinyecta el Xbox bridge; si no hay target, abre xCloud
  ./bmctl verify            Verifica Xbox virtual; si no hay target, abre xCloud
  ./bmctl axes              Muestra LX/LY/RX/RY en vivo desde xCloud
  ./bmctl buttons           Muestra palancas + LB/RB/LT/RT/Back/Start en vivo
  ./bmctl app               Abre BlackMamba Control Room
  ./bmctl app-stop          Detiene BlackMamba Control Room
  ./bmctl app-why           Diagnostica por que Control Room se apago
  ./bmctl status            Estado live-monitor + HID source + xCloud tab
  ./bmctl sessions          Historial y promedio de sesiones de juego
  ./bmctl doctor            Diagnóstico HID/xCloud compatibility
  ./bmctl doctor-advanced   Diagnóstico de estabilidad daemon/CDP/bridge/logs
  ./bmctl ram               Muestra presión de memoria y procesos BlackMamba
  ./bmctl recycle           Reinicia daemons BlackMamba y mata HID legacy del repo
  ./bmctl game-on           Activa modo juego: auto-reabre xCloud si CDP cae
  ./bmctl game-off          Desactiva modo juego: daemon no intrusivo
  ./bmctl net-on            Activa optimizador/monitor de red para cloud gaming
  ./bmctl net-off           Detiene optimizador de red
  ./bmctl net-status        Estado de latencia, jitter y perdida
  ./bmctl close             Cierra xCloud/CDP/HID/live-monitor y libera RAM
  ./bmctl shutdown          Cierra todo, incluyendo Control Room
  ./bmctl hid               Arranca fuente nativa HID -> live-monitor
  ./bmctl install-hid-agent Instala LaunchAgent persistente para HID
  ./bmctl daemon            Instala daemon completo: live + HID + xCloud bridge
  ./bmctl install-xcloud-agent Instala solo daemon de xCloud bridge
  ./bmctl uninstall-xcloud-agent Quita daemon de xCloud bridge
  ./bmctl stop-hid          Detiene fuente nativa HID
  ./bmctl lab               Abre el laboratorio visual de gamepad
  ./bmctl map               Abre el mapeador visual BlackMamba (XPout style)
  ./bmctl view              Abre el visualizador live de telemetría (Neon)
  ./bmctl fortnite-map      Mapea ABXY por posicion fisica Xbox para Fortnite
  ./bmctl switch-map        Restaura ABXY por etiquetas Nintendo/Switch
  ./bmctl test              Corre pruebas offline/live smoke
  ./bmctl save              Guarda commit local del runtime
  ./bmctl logs              Muestra logs recientes
  ./bmctl clean             Limpia caches temporales de Chrome del runtime
  ./bmctl repo-doctor       Explica que es codigo, perfil, cache y runtime local
  ./bmctl repo-clean        Cierra runtime y limpia caches repo-locales seguras
  ./bmctl preflight         Valida dependencias antes de instalar/release
  ./bmctl package-beta      Genera tar.gz beta limpio desde git

Variables útiles:
  URL=https://www.xbox.com/es-MX/play ./bmctl play
  DEBUG_PORT=9224 ./bmctl verify
HELP
}

chrome_tabs() {
  node -e "(async()=>{try{const tabs=await (await fetch('http://127.0.0.1:${DEBUG_PORT}/json')).json(); console.log(tabs.map((t,i)=>i+' '+t.type+' '+t.title+' '+t.url).join('\\n'));}catch(e){console.log('CDP no disponible en puerto ${DEBUG_PORT}')}})()"
}

kill_legacy_repo_hid() {
  local pids=()
  while IFS= read -r pid; do
    [[ -n "${pid}" ]] && pids+=("${pid}")
  done < <(pgrep -f "${ROOT}/[.]tmp-runtime-test/hid-live-source|bash -c .*${ROOT}/[.]tmp-runtime-test/hid-live-source" || true)

  if [[ "${#pids[@]}" -gt 0 ]]; then
    for pid in "${pids[@]}"; do
      pkill -P "${pid}" >/dev/null 2>&1 || true
      kill "${pid}" >/dev/null 2>&1 || true
    done
    echo "HID legacy del repo detenido: ${pids[*]}"
  fi
}

kick_agent() {
  local label="$1"
  launchctl kickstart -k "gui/$(id -u)/${label}" >/dev/null 2>&1 &
  local pid="$!"
  local waited=0
  while kill -0 "${pid}" >/dev/null 2>&1; do
    if [[ "${waited}" -ge 4 ]]; then
      kill "${pid}" >/dev/null 2>&1 || true
      echo "Aviso: kickstart timeout para ${label}; launchd lo mantiene con KeepAlive."
      return 0
    fi
    sleep 1
    waited=$((waited + 1))
  done
  wait "${pid}" >/dev/null 2>&1 || true
}

case "${1:-help}" in
  play)
    "${ROOT}/play-xcloud-cdp-bridge.sh"
    ;;
  wake)
    "${ROOT}/play-xcloud-cdp-bridge.sh"
    ;;
  reinject|reinyecta)
    "${ROOT}/start-hid-live-source.sh"
    if ! REUSE_XCLOUD=1 node "${ROOT}/runtime/inject-bridge-cdp.js" "${DEBUG_PORT}" 2>/tmp/blackmamba-bmctl-reinject.err; then
      echo "CDP/xCloud no esta activo en puerto ${DEBUG_PORT}; abriendo sesion nueva..."
      "${ROOT}/play-xcloud-cdp-bridge.sh"
    fi
    ;;
  verify|verifica)
    if ! VERIFY_ONLY=1 node "${ROOT}/runtime/inject-bridge-cdp.js" "${DEBUG_PORT}" 2>/tmp/blackmamba-bmctl-verify.err; then
      echo "CDP/xCloud no esta activo en puerto ${DEBUG_PORT}; abriendo sesion nueva y reintentando..."
      "${ROOT}/play-xcloud-cdp-bridge.sh"
      sleep 2
      VERIFY_ONLY=1 node "${ROOT}/runtime/inject-bridge-cdp.js" "${DEBUG_PORT}"
    fi
    ;;
  axes|palancas|buttons|botones)
    "${ROOT}/start-hid-live-source.sh"
    node "${ROOT}/runtime/watch-virtual-axes.js" "${DEBUG_PORT}" "${DURATION_MS:-15000}"
    ;;
  app|ui|control-room)
    mkdir -p "${ROOT}/logs"
    if ! curl -fsS "http://127.0.0.1:${APP_PORT}/api/status" >/dev/null 2>&1; then
      "${ROOT}/install-control-room-agent.sh" >/dev/null
      for _ in {1..30}; do
        if curl -fsS "http://127.0.0.1:${APP_PORT}/api/status" >/dev/null 2>&1; then
          break
        fi
        sleep 0.2
      done
    fi
    open "http://127.0.0.1:${APP_PORT}"
    echo "BlackMamba Control Room: http://127.0.0.1:${APP_PORT}"
    ;;
  app-stop|ui-stop|control-room-stop)
    "${ROOT}/close-runtime.sh" --include-app
    "${ROOT}/uninstall-control-room-agent.sh"
    ;;
  app-why|ui-why|control-room-why)
    echo "== launchctl =="
    launchctl print "gui/$(id -u)/com.blackmamba.control-room" 2>&1 | sed -n '1,180p' || true
    echo
    echo "== lifecycle =="
    tail -n 80 "${HOME}/Library/Application Support/BlackMambaInput/logs/control-room.lifecycle.log" 2>/dev/null || true
    echo
    echo "== stderr =="
    tail -n 80 "${HOME}/Library/Application Support/BlackMambaInput/logs/control-room.err.log" 2>/dev/null || true
    echo
    echo "== endpoint =="
    curl -fsS "http://127.0.0.1:${APP_PORT}/api/status" 2>&1 | head -c 1200 || true
    echo
    ;;
  setup)
    echo "== Configurando BlackMamba Runtime =="
    "${ROOT}/install-live-monitor-agent.sh"
    "${ROOT}/install-hid-live-source-agent.sh"
    "${ROOT}/install-xcloud-bridge-agent.sh"
    "${ROOT}/instalar-puente-xbox.sh"
    echo "Listo. Reinicia Chrome para activar la extension."
    ;;
  daemon)
    "${ROOT}/install-live-monitor-agent.sh"
    "${ROOT}/install-hid-live-source-agent.sh"
    "${ROOT}/install-xcloud-bridge-agent.sh"
    ;;
  status)
    echo "== live status =="
    if [[ -f "${APP_STATUS}" ]]; then sed -n '1,160p' "${APP_STATUS}"; else echo "sin live-status"; fi
    echo
    echo "== hid source =="
    HID_PID="$(pgrep -f "hid-live-source-agent.sh|[.]tmp-runtime-test/hid-live-source|BlackMambaInput/.tmp-runtime-test/hid-live-source" | head -n 1 || true)"
    if [[ -n "${HID_PID}" ]]; then
      echo "hid-live-source running pid=${HID_PID}"
    else
      echo "hid-live-source stopped (corre ./bmctl hid)"
    fi
    echo
    echo "== monitor =="
    MONITOR_PID="$(pgrep -f "live-monitor.js --port 8137|runtime/live-monitor.js" | head -n 1 || true)"
    if [[ -n "${MONITOR_PID}" ]]; then
      echo "live-monitor running pid=${MONITOR_PID}"
    else
      echo "live-monitor stopped (se inicia con ./bmctl play)"
    fi
    echo
    echo "== xcloud bridge daemon =="
    XCLOUD_PID="$(pgrep -f "xcloud-bridge-agent.js" | head -n 1 || true)"
    if [[ -n "${XCLOUD_PID}" ]]; then
      echo "xcloud-bridge-agent running pid=${XCLOUD_PID}"
    else
      echo "xcloud-bridge-agent stopped (corre ./bmctl daemon)"
    fi
    if [[ -f "${XCLOUD_STATUS}" ]]; then sed -n '1,80p' "${XCLOUD_STATUS}"; fi
    if [[ -f "${SESSION_STATUS}" ]]; then
      echo
      echo "== play sessions =="
      node -e "const fs=require('fs'); const data=JSON.parse(fs.readFileSync(process.argv[1],'utf8')); console.log(JSON.stringify(data.summary||{}, null, 2));" "${SESSION_STATUS}" 2>/dev/null || true
    fi
    if [[ -f "${NETWORK_STATUS}" ]]; then
      echo
      echo "== network game mode =="
      node -e "const fs=require('fs'); const data=JSON.parse(fs.readFileSync(process.argv[1],'utf8')); console.log(JSON.stringify({mode:data.mode, quality:data.quality, route:data.route, optimizations:data.optimizations}, null, 2));" "${NETWORK_STATUS}" 2>/dev/null || true
    fi
    echo
    echo "== chrome tabs =="
    chrome_tabs
    ;;
  sessions|session-history|play-sessions)
    if [[ -f "${SESSION_STATUS}" ]]; then
      sed -n '1,220p' "${SESSION_STATUS}"
    else
      echo "Sin historial todavia. Se crea cuando cierras una sesion larga y el agente apaga el runtime."
    fi
    ;;
  doctor)
    "${ROOT}/controller-doctor.sh" doctor
    ;;
  doctor-advanced|doctor2)
    node "${ROOT}/runtime/advanced-doctor.js"
    ;;
  ram|memory)
    echo "== memoria del sistema =="
    memory_pressure | tail -n 8
    echo
    echo "== procesos BlackMamba =="
    ps -axo pid,ppid,rss,command | rg -i 'BlackMambaInput|live-monitor|hid-live-source|xcloud-bridge' || true
    ;;
  recycle|restart-runtime)
    echo "== reciclando runtime BlackMamba =="
    kill_legacy_repo_hid
    "${ROOT}/install-live-monitor-agent.sh" >/dev/null
    "${ROOT}/install-hid-live-source-agent.sh" >/dev/null
    kick_agent "com.blackmamba.live-monitor"
    kick_agent "com.blackmamba.hid-live-source"
    kick_agent "com.blackmamba.xcloud-bridge"
    echo "Runtime reciclado. Para jugar: ./bmctl wake"
    ;;
  game-on|gaming-on)
    echo "== modo juego ON =="
    node "${ROOT}/runtime/network-game-mode.js" start || true
    if ! AUTO_OPEN_XCLOUD=1 "${ROOT}/install-xcloud-bridge-agent.sh" >/dev/null; then
      echo "Aviso: no pude activar el daemon xCloud; usando arranque directo."
    fi
    "${ROOT}/play-xcloud-cdp-bridge.sh"
    echo "Modo juego activo: el daemon reabre/reinyecta si Chrome CDP cae."
    ;;
  game-off|gaming-off)
    echo "== modo juego OFF =="
    AUTO_OPEN_XCLOUD=0 "${ROOT}/install-xcloud-bridge-agent.sh" >/dev/null
    node "${ROOT}/runtime/network-game-mode.js" stop || true
    echo "Modo no intrusivo activo: xCloud solo abre con ./bmctl wake."
    ;;
  net-on|network-on)
    node "${ROOT}/runtime/network-game-mode.js" start
    ;;
  net-off|network-off)
    node "${ROOT}/runtime/network-game-mode.js" stop
    ;;
  net-status|network-status)
    node "${ROOT}/runtime/network-game-mode.js" status
    ;;
  close|close-game|stop-game|cerrar)
    "${ROOT}/close-runtime.sh"
    ;;
  shutdown|quit|salir|kill-all)
    "${ROOT}/close-runtime.sh" --include-app
    ;;
  hid)
    "${ROOT}/start-hid-live-source.sh"
    ;;
  install-hid-agent)
    "${ROOT}/install-hid-live-source-agent.sh"
    ;;
  install-xcloud-agent)
    "${ROOT}/install-xcloud-bridge-agent.sh"
    ;;
  uninstall-xcloud-agent)
    "${ROOT}/uninstall-xcloud-bridge-agent.sh"
    ;;
  stop-hid)
    "${ROOT}/stop-hid-live-source.sh"
    ;;
  lab)
    open "file://${ROOT}/gamepad-test/index.html"
    ;;
  map)
    open "file://${ROOT}/gamepad-test/mapper.html"
    ;;
  view)
    open "file://${ROOT}/gamepad-test/visualizer.html"
    ;;
  fortnite-map)
    node "${ROOT}/runtime/apply-face-layout.js" xbox-physical
    launchctl kickstart -k "gui/$(id -u)/com.blackmamba.live-monitor" >/dev/null 2>&1 || true
    echo "Perfil Fortnite/Xbox aplicado. Si xCloud ya estaba abierto: ./bmctl reinject"
    ;;
  switch-map)
    node "${ROOT}/runtime/apply-face-layout.js" switch-labels
    launchctl kickstart -k "gui/$(id -u)/com.blackmamba.live-monitor" >/dev/null 2>&1 || true
    echo "Perfil Nintendo/Switch aplicado. Si xCloud ya estaba abierto: ./bmctl reinject"
    ;;
  test)
    "${ROOT}/test-runtime.sh"
    ;;
  logs)
    echo "== hid-live-source =="
    tail -n 60 "${ROOT}/logs/hid-live-source.log" 2>/dev/null || true
    echo
    echo "== live-monitor =="
    tail -n 40 "${HOME}/Library/Application Support/BlackMambaInput/logs/live-events.jsonl" 2>/dev/null || true
    echo
    echo "== xcloud-bridge-agent =="
    tail -n 80 "${HOME}/Library/Application Support/BlackMambaInput/logs/xcloud-bridge-agent.err.log" 2>/dev/null || true
    ;;
  clean)
    rm -rf /tmp/blackmamba-xcloud-bridge-profile /tmp/blackmamba-xcloud-bridge-verify-profile
    echo "Limpieza lista. No borre /tmp/blackmamba-xcloud-cdp-profile para no romper la sesion activa."
    ;;
  repo-doctor|repo-status|hygiene)
    "${ROOT}/repo-hygiene.sh" report
    ;;
  repo-clean|optimize-repo)
    "${ROOT}/repo-hygiene.sh" --apply
    ;;
  preflight|doctor-preflight)
    "${ROOT}/doctor-preflight.sh"
    ;;
  package-beta|release-beta)
    "${ROOT}/package-beta.sh"
    ;;
  save)
    git add -A
    git commit -m "Save BlackMamba input runtime" || true
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage
    exit 1
    ;;
esac
