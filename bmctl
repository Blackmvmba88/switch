#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEBUG_PORT="${DEBUG_PORT:-9224}"
APP_STATUS="${HOME}/Library/Application Support/BlackMambaInput/reports/live-status.json"
XCLOUD_STATUS="${HOME}/Library/Application Support/BlackMambaInput/reports/xcloud-bridge-status.json"
APP_HID_PID_FILE="${HOME}/Library/Application Support/BlackMambaInput/logs/hid-live-source.pid"
HID_BIN="${ROOT}/.tmp-runtime-test/hid-live-source"
HID_PID_FILE="${ROOT}/logs/hid-live-source.pid"

usage() {
  cat <<'HELP'
BlackMamba Input Runtime metacomandos

Uso:
  ./bmctl play              Abre xCloud con puente CDP + HID source
  ./bmctl reinject          Reinyecta el Xbox bridge; si no hay target, abre xCloud
  ./bmctl verify            Verifica Xbox virtual; si no hay target, abre xCloud
  ./bmctl axes              Muestra LX/LY/RX/RY en vivo desde xCloud
  ./bmctl status            Estado live-monitor + HID source + xCloud tab
  ./bmctl doctor            Diagnóstico HID/xCloud compatibility
  ./bmctl hid               Arranca fuente nativa HID -> live-monitor
  ./bmctl install-hid-agent Instala LaunchAgent persistente para HID
  ./bmctl daemon            Instala daemon completo: live + HID + xCloud bridge
  ./bmctl install-xcloud-agent Instala solo daemon de xCloud bridge
  ./bmctl uninstall-xcloud-agent Quita daemon de xCloud bridge
  ./bmctl stop-hid          Detiene fuente nativa HID
  ./bmctl lab               Abre el laboratorio visual de gamepad
  ./bmctl map               Abre el mapeador visual BlackMamba (XPout style)
  ./bmctl view              Abre el visualizador live de telemetría (Neon)
  ./bmctl fortnite-map      Mapea ABXY por posicion fisica Xbox para Fortnite
  ./bmctl switch-map        Restaura ABXY por etiquetas Nintendo/Switch
  ./bmctl test              Corre pruebas offline/live smoke
  ./bmctl save              Guarda commit local del runtime
  ./bmctl logs              Muestra logs recientes
  ./bmctl clean             Limpia caches temporales de Chrome del runtime

Variables útiles:
  URL=https://www.xbox.com/es-MX/play ./bmctl play
  DEBUG_PORT=9224 ./bmctl verify
HELP
}

chrome_tabs() {
  node -e "(async()=>{try{const tabs=await (await fetch('http://127.0.0.1:${DEBUG_PORT}/json')).json(); console.log(tabs.map((t,i)=>i+' '+t.type+' '+t.title+' '+t.url).join('\\n'));}catch(e){console.log('CDP no disponible en puerto ${DEBUG_PORT}')}})()"
}

case "${1:-help}" in
  play)
    "${ROOT}/play-xcloud-cdp-bridge.sh"
    ;;
  reinject|reinyecta)
    "${ROOT}/start-hid-live-source.sh"
    if ! REUSE_XCLOUD=1 node "${ROOT}/runtime/inject-bridge-cdp.js" "${DEBUG_PORT}"; then
      echo "No habia target xCloud reutilizable; abriendo sesion nueva..."
      "${ROOT}/play-xcloud-cdp-bridge.sh"
    fi
    ;;
  verify|verifica)
    if ! VERIFY_ONLY=1 node "${ROOT}/runtime/inject-bridge-cdp.js" "${DEBUG_PORT}"; then
      echo "No habia target xCloud verificable; abriendo sesion nueva y reintentando..."
      "${ROOT}/play-xcloud-cdp-bridge.sh"
      sleep 2
      VERIFY_ONLY=1 node "${ROOT}/runtime/inject-bridge-cdp.js" "${DEBUG_PORT}"
    fi
    ;;
  axes|palancas)
    "${ROOT}/start-hid-live-source.sh"
    node "${ROOT}/runtime/watch-virtual-axes.js" "${DEBUG_PORT}" "${DURATION_MS:-15000}"
    ;;
  setup)
    echo "== Configurando BlackMamba Runtime =="
    "${ROOT}/install-live-monitor-agent.sh"
    "${ROOT}/install-hid-live-source-agent.sh"
    "${ROOT}/install-xcloud-bridge-agent.sh"
    "${ROOT}/instalar-puente-xbox.sh"
    echo "Listo. Reinicia Chrome para activar la extension."
    ;;
  daemon)
    "${ROOT}/install-live-monitor-agent.sh"
    "${ROOT}/install-hid-live-source-agent.sh"
    "${ROOT}/install-xcloud-bridge-agent.sh"
    ;;
  status)
    echo "== live status =="
    if [[ -f "${APP_STATUS}" ]]; then sed -n '1,160p' "${APP_STATUS}"; else echo "sin live-status"; fi
    echo
    echo "== hid source =="
    HID_PID="$(pgrep -f "hid-live-source-agent.sh|[.]tmp-runtime-test/hid-live-source|BlackMambaInput/.tmp-runtime-test/hid-live-source" | head -n 1 || true)"
    if [[ -n "${HID_PID}" ]]; then
      echo "hid-live-source running pid=${HID_PID}"
    else
      echo "hid-live-source stopped (corre ./bmctl hid)"
    fi
    echo
    echo "== monitor =="
    MONITOR_PID="$(pgrep -f "live-monitor.js --port 8137|runtime/live-monitor.js" | head -n 1 || true)"
    if [[ -n "${MONITOR_PID}" ]]; then
      echo "live-monitor running pid=${MONITOR_PID}"
    else
      echo "live-monitor stopped (se inicia con ./bmctl play)"
    fi
    echo
    echo "== xcloud bridge daemon =="
    XCLOUD_PID="$(pgrep -f "xcloud-bridge-agent.js" | head -n 1 || true)"
    if [[ -n "${XCLOUD_PID}" ]]; then
      echo "xcloud-bridge-agent running pid=${XCLOUD_PID}"
    else
      echo "xcloud-bridge-agent stopped (corre ./bmctl daemon)"
    fi
    if [[ -f "${XCLOUD_STATUS}" ]]; then sed -n '1,80p' "${XCLOUD_STATUS}"; fi
    echo
    echo "== chrome tabs =="
    chrome_tabs
    ;;
  doctor)
    "${ROOT}/controller-doctor.sh" doctor
    ;;
  hid)
    "${ROOT}/start-hid-live-source.sh"
    ;;
  install-hid-agent)
    "${ROOT}/install-hid-live-source-agent.sh"
    ;;
  install-xcloud-agent)
    "${ROOT}/install-xcloud-bridge-agent.sh"
    ;;
  uninstall-xcloud-agent)
    "${ROOT}/uninstall-xcloud-bridge-agent.sh"
    ;;
  stop-hid)
    "${ROOT}/stop-hid-live-source.sh"
    ;;
  lab)
    open "file://${ROOT}/gamepad-test/index.html"
    ;;
  map)
    open "file://${ROOT}/gamepad-test/mapper.html"
    ;;
  view)
    open "file://${ROOT}/gamepad-test/visualizer.html"
    ;;
  fortnite-map)
    node "${ROOT}/runtime/apply-face-layout.js" xbox-physical
    launchctl kickstart -k "gui/$(id -u)/com.blackmamba.live-monitor" >/dev/null 2>&1 || true
    echo "Perfil Fortnite/Xbox aplicado. Si xCloud ya estaba abierto: ./bmctl reinject"
    ;;
  switch-map)
    node "${ROOT}/runtime/apply-face-layout.js" switch-labels
    launchctl kickstart -k "gui/$(id -u)/com.blackmamba.live-monitor" >/dev/null 2>&1 || true
    echo "Perfil Nintendo/Switch aplicado. Si xCloud ya estaba abierto: ./bmctl reinject"
    ;;
  test)
    "${ROOT}/test-runtime.sh"
    ;;
  logs)
    echo "== hid-live-source =="
    tail -n 60 "${ROOT}/logs/hid-live-source.log" 2>/dev/null || true
    echo
    echo "== live-monitor =="
    tail -n 40 "${HOME}/Library/Application Support/BlackMambaInput/logs/live-events.jsonl" 2>/dev/null || true
    echo
    echo "== xcloud-bridge-agent =="
    tail -n 80 "${HOME}/Library/Application Support/BlackMambaInput/logs/xcloud-bridge-agent.err.log" 2>/dev/null || true
    ;;
  clean)
    rm -rf /tmp/blackmamba-xcloud-bridge-profile /tmp/blackmamba-xcloud-bridge-verify-profile
    echo "Limpieza lista. No borre /tmp/blackmamba-xcloud-cdp-profile para no romper la sesion activa."
    ;;
  save)
    git add -A
    git commit -m "Save BlackMamba input runtime" || true
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage
    exit 1
    ;;
esac
