#!/usr/bin/env node
const fs = require("node:fs");
const path = require("node:path");
const http = require("node:http");

const ROOT = path.resolve(__dirname);
const STATE_PATH = path.join(ROOT, "reports", "runtime-state.json");
const API_URL = process.env.BMCTL_API_URL || "http://127.0.0.1:8147";
const BRIDGE_PATH = path.join(ROOT, "xbox-gamepad-bridge");
const CONTROLLER_DOCTOR_PATH = path.join(ROOT, "controller-doctor.sh");
const START_API_SCRIPT = process.env.BMCTL_START_API_SCRIPT || path.join(ROOT, "start-api.sh");
const PLAY_STACK_SCRIPT = process.env.BMCTL_PLAY_STACK_SCRIPT || path.join(ROOT, "play-xcloud-cdp-bridge.sh");
const CLOSE_RUNTIME_SCRIPT = process.env.BMCTL_CLOSE_RUNTIME_SCRIPT || path.join(process.env.HOME || "", "Library/Application Support/BlackMambaInput/close-runtime.sh");
const STOP_API_SCRIPT = process.env.BMCTL_STOP_API_SCRIPT || path.join(ROOT, "stop-api.sh");
const HTTP_TIMEOUT_MS = Number(process.env.BMCTL_HTTP_TIMEOUT_MS || 5000);

function loadState() {
  try {
    if (!fs.existsSync(STATE_PATH)) {
      return null;
    }
    return JSON.parse(fs.readFileSync(STATE_PATH, "utf8"));
  } catch {
    return null;
  }
}

function saveState(state) {
  fs.mkdirSync(path.dirname(STATE_PATH), { recursive: true });
  fs.writeFileSync(STATE_PATH, `${JSON.stringify(state, null, 2)}\n`);
}

function ensureState() {
  const state = loadState();
  if (state) {
    return state;
  }
  const fallback = {
    version: "1.0",
    bootedAt: new Date().toISOString(),
    mode: "standby",
    gameMode: {
      state: "idle",
      connected: false,
      graceEndsAt: null,
      lastTransitionAt: new Date().toISOString(),
      lastEvent: null
    },
    jobs: {},
    warnings: [],
    metrics: {
      restarts: 0,
      events: 0
    }
  };
  saveState(fallback);
  return fallback;
}

function requestJson(pathname) {
  return new Promise((resolve) => {
    const req = http.get(new URL(pathname, API_URL), (res) => {
      let raw = "";
      res.setEncoding("utf8");
      res.on("data", (chunk) => (raw += chunk));
      res.on("end", () => {
        try {
          resolve({ ok: res.statusCode >= 200 && res.statusCode < 300, status: res.statusCode, body: JSON.parse(raw || "{}") });
        } catch {
          resolve({ ok: false, status: res.statusCode, body: { raw } });
        }
      });
    });
    req.setTimeout(HTTP_TIMEOUT_MS, () => {
      req.destroy(new Error("request_timeout"));
    });
    req.on("error", (error) => resolve({ ok: false, status: 0, error: error.message }));
  });
}

function requestJsonWithMethod(pathname, method = "GET", body = null) {
  return new Promise((resolve) => {
    const url = new URL(pathname, API_URL);
    const req = http.request(url, {
      method,
      headers: body ? { "content-type": "application/json" } : {}
    }, (res) => {
      let raw = "";
      res.setEncoding("utf8");
      res.on("data", (chunk) => (raw += chunk));
      res.on("end", () => {
        try {
          resolve({ ok: res.statusCode >= 200 && res.statusCode < 300, status: res.statusCode, body: JSON.parse(raw || "{}") });
        } catch {
          resolve({ ok: false, status: res.statusCode, body: { raw } });
        }
      });
    });
    req.setTimeout(HTTP_TIMEOUT_MS, () => {
      req.destroy(new Error("request_timeout"));
    });
    req.on("error", (error) => resolve({ ok: false, status: 0, error: error.message }));
    if (body) {
      req.write(JSON.stringify(body));
    }
    req.end();
  });
}

function runScript(scriptPath, args = []) {
  return new Promise((resolve) => {
    if (!fs.existsSync(scriptPath)) {
      resolve({ ok: false, code: 127, stdout: "", stderr: "missing_script" });
      return;
    }
    const child = require("node:child_process").execFile("/bin/bash", [scriptPath, ...args], { cwd: ROOT, timeout: 30000 }, (error, stdout, stderr) => {
      resolve({
        ok: !error,
        code: error?.code ?? 0,
        stdout: String(stdout || ""),
        stderr: String(stderr || "")
      });
    });
    return child;
  });
}

function killMatching(pattern) {
  return new Promise((resolve) => {
    const child_process = require("node:child_process");
    let pids = [];
    try {
      pids = child_process.execFileSync("/usr/bin/pgrep", ["-f", pattern], { encoding: "utf8" })
        .split("\n")
        .map((value) => value.trim())
        .filter(Boolean);
    } catch (error) {
      if (error.status !== 1) {
        resolve({ ok: false, pattern, pids: [], error: error.message });
        return;
      }
    }
    const failed = [];
    for (const pid of pids) {
      try {
        child_process.execFileSync("/bin/kill", ["-TERM", pid], { stdio: "ignore" });
      } catch (error) {
        failed.push({ pid, error: error.message });
      }
    }
    resolve({ ok: failed.length === 0, pattern, pids, failed });
  });
}

async function ensureApiRunning() {
  const health = await requestJson("/health");
  if (health.ok) {
    return health;
  }
  const started = await runScript(START_API_SCRIPT, []);
  if (!started.ok) {
    return { ok: false, error: started.stderr || started.stdout || "api_start_failed" };
  }
  return requestJson("/health");
}

async function ensurePlayStack() {
  return runScript(PLAY_STACK_SCRIPT, []);
}

function summarizeRuntime(runtime) {
  return {
    state: runtime?.state || null,
    active: runtime?.active === true,
    bootedAt: runtime?.bootedAt || null,
    uptimeMs: runtime?.uptimeMs ?? null
  };
}

function frontmostApp() {
  return new Promise((resolve) => {
    require("node:child_process").execFile("/usr/bin/osascript", [
      "-e",
      'tell application "System Events" to get name of first application process whose frontmost is true'
    ], { timeout: 3000 }, (error, stdout) => {
      resolve(error ? "" : String(stdout || "").trim());
    });
  });
}

function activateApp(appName) {
  return new Promise((resolve) => {
    require("node:child_process").execFile("/usr/bin/osascript", [
      "-e",
      `tell application "${appName}" to activate`
    ], { timeout: 5000 }, (error, stdout, stderr) => {
      resolve({ ok: !error, stdout: String(stdout || "").trim(), stderr: String(stderr || "").trim() });
    });
  });
}

async function focusGameWindow() {
  const xcloudStatusPath = path.join(process.env.HOME || "", "Library/Application Support/BlackMambaInput/reports/xcloud-bridge-status.json");
  let browserPreference = "";
  try {
    if (fs.existsSync(xcloudStatusPath)) {
      const status = JSON.parse(fs.readFileSync(xcloudStatusPath, "utf8"));
      browserPreference = String(status.browserApp || "").trim();
    }
  } catch {
    browserPreference = "";
  }
  const browserChoices = browserPreference === "ChatGPT Atlas"
    ? ["ChatGPT Atlas", "Google Chrome"]
    : ["Google Chrome", "ChatGPT Atlas"];
  for (const appName of browserChoices) {
    const activated = await activateApp(appName);
    if (!activated.ok) {
      continue;
    }
    await new Promise((resolve) => setTimeout(resolve, 500));
    const current = await frontmostApp();
    if (new RegExp(appName.replace(/[.*+?^${}()|[\]\\]/g, "\\$&"), "i").test(current)) {
      return { ok: true, app: current || appName };
    }
  }
  return { ok: false, app: await frontmostApp() };
}

async function main() {
  const command = process.argv[2];
  if (!command || ["status", "doctor", "verify", "ready", "focus", "open", "work", "play", "close"].indexOf(command) === -1) {
    console.error("usage: bmctl <status|doctor|verify|ready|focus|open|work|play|close>");
    process.exit(2);
  }

  if (command === "status") {
    const state = ensureState();
    if (!state) {
      console.log("runtime: unavailable");
      process.exit(1);
    }
    console.log(JSON.stringify({ ok: true, runtime: state.mode, gameMode: state.gameMode }, null, 2));
    process.exit(0);
  }

  if (command === "doctor") {
    const state = ensureState();
    const checks = [];
    checks.push({ name: "runtime-state", status: state ? "ok" : "error" });
    checks.push({ name: "api-server", status: await requestJson("/health").then((r) => (r.ok ? "ok" : "error")) });
    checks.push({ name: "control-detected", status: state?.gameMode?.connected ? "ok" : "warning" });
    checks.push({ name: "game-bridge", status: fs.existsSync(BRIDGE_PATH) ? "ok" : "warning" });
    checks.push({ name: "controller-doctor", status: fs.existsSync(CONTROLLER_DOCTOR_PATH) ? "ok" : "warning" });
    console.log(JSON.stringify({ ok: checks.every((c) => c.status !== "error"), checks }, null, 2));
    process.exit(checks.some((c) => c.status === "error") ? 1 : 0);
  }

  if (command === "verify") {
    const health = await requestJson("/health");
    const runtime = await requestJson("/api/v1/runtime");
    const ok = health.ok && runtime.ok && runtime.body?.runtime?.active === true;
    console.log(JSON.stringify({ ok, health: health.body, runtime: runtime.body }, null, 2));
    process.exit(ok ? 0 : 1);
  }

  if (command === "focus") {
    const result = await focusGameWindow();
    const frontmost = await frontmostApp();
    const ok = Boolean(result.ok);
    console.log(JSON.stringify({
      ok,
      focused: result.ok,
      frontmostApp: frontmost || null,
      targetApp: result.app || null
    }, null, 2));
    process.exit(ok ? 0 : 1);
  }

  if (command === "ready") {
    const health = await requestJson("/health");
    const runtime = await requestJson("/api/v1/runtime");
    const xcloudStatusPath = path.join(process.env.HOME || "", "Library/Application Support/BlackMambaInput/reports/xcloud-bridge-status.json");
    let xcloud = null;
    try {
      if (fs.existsSync(xcloudStatusPath)) {
        xcloud = JSON.parse(fs.readFileSync(xcloudStatusPath, "utf8"));
      }
    } catch {
      xcloud = null;
    }
    const frontmost = await frontmostApp();
    const frontmostOk = /Google Chrome|ChatGPT Atlas/i.test(frontmost);
    const xcloudReady = xcloud?.state === "injected" || xcloud?.playTarget === true;
    const runtimeReady = runtime.ok && runtime.body?.runtime?.active === true && runtime.body?.gameMode?.connected === true;
    const controlDetected = runtime.ok && runtime.body?.gameMode?.state === "running";
    let focusAttempt = null;
    let focusedOk = frontmostOk;
    if (!focusedOk && health.ok && runtimeReady && xcloudReady) {
      focusAttempt = await focusGameWindow();
      focusedOk = Boolean(focusAttempt.ok);
    }
    const ok = Boolean(health.ok && runtimeReady && xcloudReady && focusedOk);
    console.log(JSON.stringify({
      ok,
      ready: ok ? "ready_to_play" : "not_ready",
      checks: {
        api: health.ok,
        runtime: runtimeReady,
        control: controlDetected,
        bridge: xcloudReady,
        frontmost: focusedOk
      },
      frontmostApp: (focusAttempt?.app || frontmost) || null,
      focusAttempt: focusAttempt ? { ok: focusAttempt.ok, app: focusAttempt.app || null } : null,
      runtime: summarizeRuntime(runtime.body?.runtime),
      gameMode: runtime.body?.gameMode || null,
      bridge: xcloud ? {
        state: xcloud.state || null,
        cdp: xcloud.cdp || null,
        playTarget: Boolean(xcloud.playTarget),
        activeSession: Boolean(xcloud.activeSession)
      } : null
    }, null, 2));
    process.exit(ok ? 0 : 1);
  }

  if (command === "open") {
    const api = await ensureApiRunning();
    const stack = await ensurePlayStack();
    const runtime = await requestJson("/api/v1/runtime");
    const connect = await requestJsonWithMethod("/api/v1/game/connect", "POST", { source: "bmctl", label: "open" });
    const focusAttempt = await focusGameWindow();
    const state = ensureState();
    state.mode = "game";
    state.gameMode = {
      ...(state.gameMode || {}),
      connected: true,
      state: "running",
      graceEndsAt: null,
      lastTransitionAt: new Date().toISOString(),
      lastEvent: { type: "open", detail: { source: "bmctl" }, at: new Date().toISOString() }
    };
    saveState(state);
    const ok = Boolean(api.ok && stack.ok && connect.ok);
    console.log(JSON.stringify({
      ok,
      mode: "open",
      focusAttempt,
      api: api.body || api.error || null,
      stack: { ok: stack.ok, code: stack.code, stdout: stack.stdout || "", stderr: stack.stderr || "" },
      connect: connect.body || null,
      runtime: summarizeRuntime(runtime.body?.runtime),
      gameMode: runtime.body?.gameMode || state.gameMode
    }, null, 2));
    process.exit(ok ? 0 : 1);
  }

  if (command === "work") {
    console.log(JSON.stringify({ ok: true, mode: "work", action: "prepared" }, null, 2));
    process.exit(0);
  }

  if (command === "play") {
    const api = await ensureApiRunning();
    const runtimeBefore = await requestJson("/api/v1/runtime");
    const alreadyActive = runtimeBefore.ok && runtimeBefore.body?.runtime?.active === true;
    const bridgeReady = fs.existsSync(BRIDGE_PATH);
    const stack = alreadyActive && bridgeReady ? { ok: true, code: 0, stdout: "already_active", stderr: "" } : await ensurePlayStack();
    const connect = await requestJsonWithMethod(alreadyActive ? "/api/v1/game/reconnect" : "/api/v1/game/connect", "POST", { source: "bmctl", label: "play" });
    const runtimeAfter = await requestJson("/api/v1/runtime");
    const focusAttempt = await focusGameWindow();
    const state = ensureState();
    state.mode = "game";
    state.gameMode = {
      ...(state.gameMode || {}),
      connected: true,
      state: "running",
      graceEndsAt: null,
      lastTransitionAt: new Date().toISOString(),
      lastEvent: { type: "play", detail: { source: "bmctl", alreadyActive }, at: new Date().toISOString() }
    };
    saveState(state);
    const ok = Boolean(api.ok && stack.ok && connect.ok && runtimeAfter.ok && runtimeAfter.body?.runtime?.active === true);
    console.log(JSON.stringify({
      ok,
      mode: "play",
      alreadyActive,
      bridgeReady,
      focusAttempt,
      api: api.body || api.error || null,
      stack: { ok: stack.ok, code: stack.code, stdout: stack.stdout || "", stderr: stack.stderr || "" },
      connect: connect.body || null,
      runtime: summarizeRuntime(runtimeAfter.body?.runtime),
      gameMode: runtimeAfter.body?.gameMode || state.gameMode
    }, null, 2));
    process.exit(ok ? 0 : 1);
  }

  if (command === "close") {
    const before = await requestJson("/api/v1/runtime");
    const closeResult = await requestJsonWithMethod("/api/v1/game/close", "POST", { source: "bmctl", label: "close" });
    const runtimeShutdown = await runScript(CLOSE_RUNTIME_SCRIPT, []);
    const apiShutdown = await runScript(STOP_API_SCRIPT, []);
    let after = await requestJson("/api/v1/runtime");
    let fallbackReason = null;

    if (!after.ok || !closeResult.ok) {
      const state = ensureState();
      if (state) {
        state.mode = "standby";
        state.gameMode = {
          ...(state.gameMode || {}),
          connected: false,
          state: "stopped",
          graceEndsAt: null,
          lastTransitionAt: new Date().toISOString(),
          lastEvent: { type: "close", detail: { source: "bmctl", fallback: true }, at: new Date().toISOString() }
        };
        saveState(state);
        fallbackReason = "api_unavailable";
        after = { ok: true, body: { runtime: { state: "standby", active: false }, gameMode: state.gameMode } };
      }
    }

    const ok = Boolean(after.ok && after.body?.runtime?.active === false && after.body?.gameMode?.state === "stopped");
    console.log(JSON.stringify({
      ok,
      mode: "close",
      before: before.body?.runtime || null,
      closeResult: closeResult.body || null,
      runtimeShutdown: runtimeShutdown.stdout ? runtimeShutdown.stdout.trim() : runtimeShutdown.stderr || null,
      apiShutdown: apiShutdown.stdout ? apiShutdown.stdout.trim() : apiShutdown.stderr || null,
      after: after.body?.runtime || null,
      fallbackReason
    }, null, 2));
    process.exit(ok ? 0 : 1);
  }
}

main();
